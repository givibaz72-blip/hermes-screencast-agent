{
  "title": "Hermes public demo",
  "target": {
    "kind": "web",
    "url": "https://example.com"
  },
  "preferences": {
    "resolution": "1080p",
    "cursor_speed": "natural",
    "highlight_style": "subtle",
    "marker_colors": [
      "yellow"
    ],
    "pacing": "professional",
    "browser_ui": "visible"
  },
  "metadata": {
    "schema": "hermes.demo.v1",
    "mode": "public"
  },
  "steps": [
    {
      "action": "goto",
      "url": "https://example.com"
    },
    {
      "action": "wait",
      "seconds": 1
    },
    {
      "action": "narration",
      "text": "Hermes records a professional browser demonstration"
    },
    {
      "action": "wait",
      "seconds": 1
    },
    {
      "action": "hover",
      "selector": "a"
    },
    {
      "action": "draw_box",
      "selector": "a"
    },
    {
      "action": "wait",
      "seconds": 2
    }
  ]
}
